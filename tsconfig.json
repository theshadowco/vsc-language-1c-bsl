{
	"compilerOptions": {
        "baseUrl": ".",
        "paths": { "*": ["types/*"] },
		"module": "node16",
		"moduleResolution": "node16",
		"target": "es6",
		"outDir": "out",
		"lib": [
			"es6"
		],
		"sourceMap": true,
		"skipLibCheck": true
	},
	"exclude": [
		"node_modules"
	]
}
